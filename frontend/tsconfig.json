{
  "compilerOptions": {
    "noImplicitAny": false,
    "target": "es2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node", "vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "app/*": ["./src/app/*"],
      "entryPointFactory": ["./src/entryPointFactory.tsx"],
      "globalConstants": ["./src/globalConstants.ts"],
      "locales/*": ["./src/locales/*"],
      "redux/*": ["./src/redux/*"],
      "styles/*": ["./src/styles/*"],
      "types": ["./src/types.ts"],
      "types/*": ["./src/types/*"],
      "utils/*": ["./src/utils/*"]
    }
  },
  "include": ["src"]
}
