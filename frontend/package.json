  "scripts": {
    "bootstrap": "npm install --legacy-peer-deps",
    "start": "vite --host 0.0.0.0",
    "dev:vite": "npm run start",
    "build": "vite build",
    "build:vite": "vite build",
    "build:task": "vite build --config vite.task.config.mts",
    "build:all": "npm run build && npm run build:task",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --reporter=default",
    "test:jest": "jest --config jest.config.js",
    "checkTs": "tsc --noEmit",
    "eslint": "eslint --ext js,ts,tsx",
    "lint": "npm run eslint src",
    "lint:fix": "npm run eslint --fix src",
    "lint:css": "npx stylelint \"src/**/*.css\"",
    "lint:style": "npx stylelint \"src/**/*.{js,ts,jsx,tsx}\"",
    "prettify": "prettier --write src",
    "prepare": "cd .. && husky install frontend/.husky",
    "doc:types": "tsc --project tsconfig.dHelper.json"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "npm run eslint --fix",
      "npm run lint:style",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  },
