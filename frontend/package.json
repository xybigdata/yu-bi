{
  "name": "yu-bi",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "repository": {
    "type": "git",
    "url": "git@github.com:xybigdata/yu-bi.git"
  },
  "engines": {
    "npm": ">=11.0.0",
    "node": ">=24.0.0"
  },
  "author": "chencongyu <congyu_email@163.com>",
  "license": "Apache-2.0",
  "scripts": {
    "bootstrap": "npm install",
    "start": "vite --host 0.0.0.0",
    "dev:vite": "npm run start",
    "build": "vite build",
    "build:vite": "vite build",
    "build:task": "vite build --config vite.task.config.mts",
    "build:all": "npm run build && npm run build:task",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --reporter=default",
    "checkTs": "tsc --noEmit",
    "eslint": "eslint",
    "lint": "npm run eslint -- src",
    "lint:fix": "npm run eslint -- --fix src",
    "lint:css": "npx stylelint \"src/**/*.css\"",
    "lint:style": "npx stylelint \"src/**/*.{js,ts,jsx,tsx}\"",
    "lint:style:staged": "npx stylelint",
    "prettify": "prettier --write src",
    "prepare": "cd .. && npx --prefix frontend husky frontend/.husky",
    "doc:types": "tsc --project tsconfig.dHelper.json"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "npm run eslint -- --fix",
      "npm run lint:style:staged --",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@ant-design/pro-components": "^2.8.10",
    "@antv/s2": "^2.7.2",
    "@antv/s2-react": "^2.3.1",
    "@hello-pangea/dnd": "18.0.1",
    "@reduxjs/toolkit": "2.12.0",
    "antd": "^5.26.2",
    "axios": "1.17.0",
    "classnames": "^2.3.1",
    "dayjs": "^1.11.21",
    "echarts": "5.6.0",
    "echarts-wordcloud": "^2.1.0",
    "flexlayout-react": "^0.9.1",
    "i18next": "^26.0.2",
    "immer": "^9.0.5",
    "lodash": "^4.17.21",
    "monaco-editor": "0.52.2",
    "polished": "^4.1.1",
    "react": "18.3.1",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "18.3.1",
    "react-draggable": "^4.7.0",
    "react-grid-layout": "^2.2.3",
    "react-helmet-async": "3.0.0",
    "react-hotkeys-hook": "^3.4.0",
    "react-i18next": "^17.0.8",
    "react-quill": "^2.0.0",
    "react-redux": "9.3.0",
    "react-resizable": "^3.2.0",
    "react-router-dom": "^6.30.1",
    "react-window": "^1.8.11",
    "redux-undo": "^1.0.1",
    "reveal.js": "^6.0.1",
    "split.js": "^1.6.4",
    "sql-formatter": "9.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "14.3.1",
    "@testing-library/user-event": "14.6.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "24.13.2",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@types/react-resizable": "^3.0.8",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^4.7.0",
    "babel-plugin-styled-components": "^2.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "less": "^4.6.6",
    "lint-staged": "^17.0.8",
    "postcss": "^8.4.6",
    "postcss-styled-syntax": "^0.7.1",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "styled-components": "6.1.19",
    "stylelint": "^17.13.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-order": "^7.0.0",
    "typescript": "5.9.3",
    "vite": "^6.4.3",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.1.9"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
